ANTHROPIC_API_KEY=sk-ant-...

# Populated from data_analyst_agent.ipynb output; consumed by slack_data_bot.ipynb
ANALYST_ENV_ID=env_...
ANALYST_AGENT_ID=agent_...
ANALYST_AGENT_VERSION=...

# For slack_data_bot.ipynb
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Required for the GitHub MCP sidebar in CMA_orchestrate_issue_to_pr.ipynb
# and the vault-backed MCP credentials in CMA_operate_in_production.ipynb
GITHUB_TOKEN=ghp_...

# Optional — override the default model used by the CMA_ tutorials
COOKBOOK_MODEL=claude-sonnet-4-6

# For sre_incident_responder.ipynb (production wiring only)
DD_API_KEY=
DD_APP_KEY=

# For CMA_with_mongodb_atlas.ipynb
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/   # Atlas SRV connection string (host-side only)
# Embeddings + rerank provider (optional — the seed ships precomputed vectors). Pick ONE:
MDB_ATLAS_API_KEY=     # MongoDB Atlas AI endpoint (serves /v1/embeddings AND /v1/rerank)
VOYAGE_API_KEY=        # or the voyageai SDK directly (embeddings + rerank)
ENABLE_RERANK=         # set to 1 to enable the rerank stage (uses whichever key above is set)
AUTO_APPROVE=          # set to 1 for a non-interactive human gate (CI / unattended runs)
